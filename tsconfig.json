{
  "compilerOptions": {
    "lib": ["ES2020", "dom"],
    "allowJs": true,
    "module": "esnext",
    "target": "ES2020",
    "strict": true,
    "noUnusedLocals": true,
    "declaration": true,
    "jsx": "react",
    "skipLibCheck": true,
    "types": ["node", "jest", "bun"]
  },
  "include": ["src"],
  "exclude": ["bin", "esm", "cjs"]
}
